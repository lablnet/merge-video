#!/bin/bash

# 1. Check for ffmpeg and install if missing
if ! command -v ffmpeg &> /dev/null; then
    echo "Umer, ffmpeg is not installed. Trying to install it now... 🛠️"
    
    # Check for Homebrew
    if ! command -v brew &> /dev/null; then
        echo "Homebrew not found. Installing Homebrew first... 🍺"
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi
    
    brew install ffmpeg
else
    echo "ffmpeg is already installed! Ready to go, Umer. ✅"
fi

# Parse optional --last argument
LAST_FIRST=false
for arg in "$@"; do
    if [ "$arg" == "--last" ]; then
        LAST_FIRST=true
    fi
done

# 2. Create a list of files sorted by time
echo "Finding and sorting your MP4 files... 📄"

# Get all mp4 files sorted by time (oldest first), excluding the output file
# Using a loop instead of mapfile for compatibility with macOS's default bash 3.2
files=()
while IFS=  read -r line; do
    [[ -n "$line" ]] && files+=("$line")
done < <(ls -tr *.mp4 2>/dev/null | grep -v "merged_output.mp4")

if [ ${#files[@]} -eq 0 ]; then
    echo "No MP4 files found in this folder! ❌"
    exit 1
fi

rm -f filelist.txt

if [ "$LAST_FIRST" = true ]; then
    echo "Flag --last detected! Putting the newest video first. 🕒"
    # Get the last (newest) file
    last_idx=$((${#files[@]} - 1))
    last_file="${files[$last_idx]}"
    echo "file '$last_file'" >> filelist.txt
    
    # Add the rest of the files in order (excluding the last one)
    for (( i=0; i<$last_idx; i++ )); do
        echo "file '${files[$i]}'" >> filelist.txt
    done
else
    # Regular order: oldest to newest
    for f in "${files[@]}"; do
        echo "file '$f'" >> filelist.txt
    done
fi


# 3. Merge the files using ffmpeg
if [ -f filelist.txt ]; then
    echo "Merging files into merged_output.mp4... 🎥"
    ffmpeg -f concat -safe 0 -i filelist.txt -c copy merged_output.mp4
    echo "Done! Your video is ready, Umer! 🥳"
    rm filelist.txt
else
    echo "Something went wrong creating the file list. ❌"
fi

